# NoterAI configuration — copy to .env and fill in values

# Database
DATABASE_URL=./notes.db

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=notes

# Embeddings (OpenAI-compatible /v1/embeddings endpoint)
EMBEDDING_BASE_URL=http://localhost:8080
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_BATCH_SIZE=32

# Chunking
CHUNK_SIZE=350
CHUNK_OVERLAP=64
# Hard character ceiling per chunk — lower if embedding server has small context window
CHUNK_MAX_CHARS=500
# Chunks embedded+upserted per round-trip (limits peak memory for large PDFs)
INDEX_BATCH_SIZE=200

# Storage
ATTACHMENT_DIR=./attachments

# App URL (used in Android PWA manifest and share target)
APP_BASE_URL=https://localhost:8443

# LLM summaries (OpenAI-compatible /v1/chat/completions endpoint — optional)
# Without this, summaries fall back to text truncation
SUMMARY_BASE_URL=
SUMMARY_MODEL=gpt-4o-mini
SUMMARY_API_KEY=

# RAG chat API
CHAT_LLM_BASE_URL=    # falls back to SUMMARY_BASE_URL
CHAT_LLM_MODEL=       # falls back to SUMMARY_MODEL
CHAT_N_RESULTS=8
CHAT_PORT=8084

# Telegram Bot (optional — bot only starts if TELEGRAM_BOT_TOKEN is set)
TELEGRAM_BOT_TOKEN=                  # from @BotFather
TELEGRAM_ALLOWED_USERS=              # comma-separated Telegram user IDs (integers)
TELEGRAM_MAX_HISTORY=20              # conversation turns kept per chat
TELEGRAM_RAG_URL=http://localhost:8084
TELEGRAM_RAG_MODEL=noterai-rag
TELEGRAM_REMINDER_HOURS=8,14         # 24h hours to send scheduled reminders
TELEGRAM_REMINDER_CHAT_ID=           # your DM chat ID with the bot (use /chatid to find)
